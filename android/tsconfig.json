{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["src/*"]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "plugins", "App.tsx", "index.ts", "app.config.ts", "jest.setup.ts"]
}
